# picpeak-credentials.properties.example
#
# Copy this file to picpeak-credentials.properties and fill in your credentials.
# picpeak-credentials.properties is loaded automatically by the convenience scripts when
# present in the same directory.  It is listed in .gitignore so credentials
# are never committed.
#
# Only settings that differ from the defaults need to be listed here.
# All defaults come from PicPeakProperties (Java constructor) and
# application.properties.  See README.md § "All PicPeak Settings" for the
# full list.

# Credentials (required)

app.schulfotos.base-url=https://example.com/schulfotos
app.schulfotos.gallery-url=https://example.com/schulfotos/?code=

app.picpeak.enabled=true
app.picpeak.api-url=https://pics.example.com
app.picpeak.username=
app.picpeak.password=

# Overrides (optional — only list values that differ from defaults)
# app.picpeak.customer-email=
# app.picpeak.admin-email=
# app.picpeak.expiration-days=30
# app.picpeak.event-type=schulfotos
# app.picpeak.feedback-enabled=true
# app.picpeak.moderate-comments=true
